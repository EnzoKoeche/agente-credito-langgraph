# === agente-credito-langgraph — exemplo de variaveis de ambiente ===
# Copie para `.env` (que e IGNORADO pelo git desde o commit zero) e preencha.
# NUNCA commite a chave real. Este arquivo contem APENAS placeholders.

# --- Anthropic (caminho real do extrator/pre-parecer) ---
ANTHROPIC_API_KEY=sk-ant-COLOQUE_SUA_CHAVE_AQUI
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Checkpointing (SqliteSaver) ---
CHECKPOINT_DB=checkpoints.sqlite

# --- Observabilidade (Fase 2 — Langfuse), opcional ---
LANGFUSE_PUBLIC_KEY=pk-lf-PLACEHOLDER
LANGFUSE_SECRET_KEY=sk-lf-PLACEHOLDER
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Execucao ---
# MODO=demo usa extrator mock injetavel (sem custo de API); MODO=real chama a Anthropic.
MODO=demo
